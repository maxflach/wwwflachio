<?xml version="1.0" encoding="UTF-8"?>
<clientConfig version="1.1">
  <emailProvider id="flach.io">
    <domain>flach.io</domain>
    <displayName>flach.io Email</displayName>
    <displayShortName>Flach</displayShortName>
    
    <incomingServer type="imap">
      <hostname>mail.privateemail.com</hostname>
      <port>993</port>
      <socketType>SSL</socketType>
      <username>%EMAILADDRESS%</username>
      <authentication>password-cleartext</authentication>
    </incomingServer>
    
    <incomingServer type="pop3">
      <hostname>mail.privateemail.com</hostname>
      <port>995</port>
      <socketType>SSL</socketType>
      <username>%EMAILADDRESS%</username>
      <authentication>password-cleartext</authentication>
    </incomingServer>
    
    <outgoingServer type="smtp">
      <hostname>mail.privateemail.com</hostname>
      <port>587</port>
      <socketType>STARTTLS</socketType>
      <username>%EMAILADDRESS%</username>
      <authentication>password-cleartext</authentication>
    </outgoingServer>
    
    <outgoingServer type="smtp">
      <hostname>mail.privateemail.com</hostname>
      <port>465</port>
      <socketType>SSL</socketType>
      <username>%EMAILADDRESS%</username>
      <authentication>password-cleartext</authentication>
    </outgoingServer>
  </emailProvider>
</clientConfig>